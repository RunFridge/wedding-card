{
  "name": "wedding-card-frontend",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-og": "tsx scripts/generate-og.ts",
    "build": "tsx scripts/generate-og.ts && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "cropperjs": "^1.6.2",
    "lucide-vue-next": "^0.577.0",
    "phaser": "^3.90.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "satori": "^0.19.2",
    "satori-html": "^0.3.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.4",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.4"
  }
}
